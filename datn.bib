@article{darmawahyuniAccurateFetalQRSComplex2023,
  title = {Accurate {{Fetal QRS-Complex Classification}} from {{Abdominal Electrocardiogram Using Deep Learning}}},
  author = {Darmawahyuni, Annisa and Tutuko, Bambang and Nurmaini, Siti and Rachmatullah, Muhammad Naufal and Ardiansyah, Muhammad and Firdaus, Firdaus and Sapitri, Ade Iriani and Islami, Anggun},
  date = {2023-09},
  journaltitle = {International Journal of Computational Intelligence Systems},
  volume = {16},
  number = {1},
  pages = {158},
  issn = {1875-6883},
  doi = {10.1007/s44196-023-00339-x},
  url = {https://doi.org/10.1007/s44196-023-00339-x},
  urldate = {2026-02-28},
  abstract = {Fetal heart monitoring during pregnancy plays a critical role in diagnosing congenital heart disease (CHD). A noninvasive fetal electrocardiogram (fECG) provides additional clinical information for fetal heart monitoring. To date, the analysis of noninvasive fECG is challenging due to the cancellation of maternal QRS-complexes, despite significant advances in electrocardiography. Fetal QRS-complex is highly considered to measure fetal heart rate to detect some fetal abnormalities such as arrhythmia. In this study, we proposed a deep learning (DL) framework that stacked a convolutional layer and bidirectional long short-term memory for fetal QRS-complexes classification. The fECG signals are first preprocessed using discrete wavelet transform (DWT) to remove the noise or inferences. The following step beats and QRS-complex segmentation. The last step is fetal QRS-complex classification based on DL. In the experiment of Physionet/Computing in Cardiology Challenge 2013, this study achieved 100\% accuracy, sensitivity, specificity, precision, and F1-score. A stacked DL model demonstrates an effective tool for fetal QRS-complex classification and contributes to clinical applications for long-term maternal and fetal monitoring.},
  langid = {english},
  keywords = {Deep learning,Fetal electrocardiogram,QRS-complex}
}

@inproceedings{darmawahyuniDeepLearningFetal2023,
  title = {Deep {{Learning}} for {{Fetal QRS-complex Classification}} in {{Noninvasive Fetal Electrocardiogram}}},
  booktitle = {2023 {{International Conference}} on {{Data Science}} and {{Its Applications}} ({{ICoDSA}})},
  author = {Darmawahyuni, Annisa and Tutuko, Bambang and Rachmatullah, Muhammad Naufal and Nurmaini, Siti and Firdaus, Firdaus and Ardiansyah, Muhammad and Sapitri, Ade Iriani and Islami, Anggun},
  date = {2023-08},
  pages = {215--218},
  doi = {10.1109/ICoDSA58501.2023.10277016},
  url = {https://ieeexplore.ieee.org/document/10277016},
  urldate = {2026-02-28},
  abstract = {Fetal QRS-complex generated from an abdominal electrocardiogram (ECG) is an effective noninvasive tool for accurately measuring the fetus well-being during pregnancy. Classification of fetal QRS is significant to avoid fetal heart abnormalities, such as asphyxia, bradycardia, and hypoxia. However, accurately classifying the fetal QRS-complex is hard because the characteristic fetal ECG (fECG) has small amount of signal energy and it has undesired signal components, including recording devices, movement artifacts, and fetal brain activity. The sophisticated fECG signal processing for fetal QRS-complex classification has been used in the literature. However, they mostly use human intervention for feature extraction, leading to time-consume and raising the measurement error. Hence, this study investigates deep learning (DL) that performs automated feature extraction tasks excellently. DL has excellence amount of data scales, which is its ability to automatically learn and improve from data without the need for explicit programming. A sequence-to-sequence learning task was generated using a hybrid four convolution layers as a part of convolutional neural networks and bidirectional long short-term memory (ConvBiLSTM). As the results, the performance is outstanding; the accuracy, sensitivity, specificity, precision, and F1-score were 100\%. The observed results show the proposed ConvBiLSTM model is worth evaluating their effectiveness for fetal QRS-complex classification.},
  keywords = {convBiLSTM,Convolution,deep learning,Deep learning,Electrocardiography,Feature extraction,fetal electrocardiogram,Programming,qrs-complex,Sensitivity,Signal processing algorithms}
}

@article{departmentofgeneralmedicineamalainstituteofmedicalsciencesthrissurkeralaindiLaboratoryWearablesReview2022,
  title = {From a Laboratory to the Wearables: A Review on History and Evolution of Electrocardiogram},
  shorttitle = {From a Laboratory to the Wearables},
  author = {{Department of General Medicine, Amala Institute of Medical Sciences, Thrissur, Kerala, Indi} and Vincent, Rony},
  date = {2022-09},
  journaltitle = {Iberoamerican Journal of Medicine},
  volume = {4},
  number = {4},
  pages = {248--255},
  issn = {26955075},
  doi = {10.53986/ibjm.2022.0038},
  url = {https://www.iberoamjmed.com/article/doi/10.53986/ibjm.2022.0038},
  urldate = {2026-02-15},
  abstract = {The development of electrocardiography, one of the top scientific breakthroughs of the 20th century, occurred in the field of cardiology. The history of the ECG began long before its invention, with the advent of the study of electricity in the medical field. The idea of electrophysiology and Waller's initial recording of the ‘electrogram’ encouraged Willem Einthoven to develop new string galvanometers and turn this remarkable physiologic occurrence into a vital clinical recording tool. It has progressed from Einthoven's innovation to wearable technology. In the first part of the 20th century, a number of inventive people achieved a remarkable succession of discoveries and advancements that led to the development of the 12-lead ECG as we know it today. It went further than that. The evolution of science and technology over the years has allowed for continual development in terms of usefulness, ranging from five operators to one operator meant to record the ECG trace, and mobility, ranging from around 300 Kg to roughly around 1 Kg. Electrocardiographs in minimized form now exist thanks to the modern era of digitalization. We will go over the significant processes in the development of the ECG in this article.},
  langid = {english}
}

@article{devriesFetalElectrocardiographyArtificial2023,
  title = {Fetal Electrocardiography and Artificial Intelligence for Prenatal Detection of Congenital Heart Disease},
  author = {family=Vries, given=Ivar R., prefix=de, useprefix=true and family=Laar, given=Judith O. E. H., prefix=van, useprefix=true and family=Hout-van der Jagt, given=Marieke B., prefix=van der, useprefix=true and Clur, Sally-Ann B. and Vullings, Rik},
  date = {2023-11},
  journaltitle = {Acta Obstetricia Et Gynecologica Scandinavica},
  shortjournal = {Acta Obstet Gynecol Scand},
  volume = {102},
  number = {11},
  eprint = {37563851},
  eprinttype = {pubmed},
  pages = {1511--1520},
  issn = {1600-0412},
  doi = {10.1111/aogs.14623},
  abstract = {INTRODUCTION: This study aims to investigate non-invasive electrocardiography as a method for the detection of congenital heart disease (CHD) with the help of artificial intelligence. MATERIAL AND METHODS: An artificial neural network was trained for the identification of CHD using non-invasively obtained fetal electrocardiograms. With the help of a Bayesian updating rule, multiple electrocardiographs were used to increase the algorithm's performance. RESULTS: Using 122 measurements containing 65 healthy and 57 CHD cases, the accuracy, sensitivity, and specificity were found to be 71\%, 63\%, and 77\%, respectively. The sensitivity was however 75\% and 69\% for CHD cases requiring an intervention in the neonatal period and first year of life, respectively. Furthermore, a positive effect of measurement length on the detection performance was observed, reaching optimal performance when using 14 electrocardiography segments (37.5\,min) or more. A small negative trend between gestational age and accuracy was found. CONCLUSIONS: The proposed method combining recent advances in obtaining non-invasive fetal electrocardiography with artificial intelligence for the automatic detection of CHD achieved a detection rate of 63\% for all CHD and 75\% for critical CHD. This feasibility study shows that detection rates of CHD might improve by using electrocardiography-based screening complementary to the standard ultrasound-based screening. More research is required to improve performance and determine the benefits to clinical practice.},
  langid = {english},
  pmcid = {PMC10577634},
  keywords = {artificial intelligence,Artificial Intelligence,Bayes Theorem,congenital heart disease,Electrocardiography,Female,fetal electrocardiography,fetal heart,Fetal Heart,Heart Defects Congenital,Humans,Infant Newborn,Pregnancy,prenatal diagnosis,Ultrasonography Prenatal},
  file = {C:\Users\Minh\Zotero\storage\QVF4C47W\de Vries et al. - 2023 - Fetal electrocardiography and artificial intelligence for prenatal detection of congenital heart dis.pdf}
}

@misc{dosovitskiyImageWorth16x162021,
  title = {An {{Image}} Is {{Worth}} 16x16 {{Words}}: {{Transformers}} for {{Image Recognition}} at {{Scale}}},
  shorttitle = {An {{Image}} Is {{Worth}} 16x16 {{Words}}},
  author = {Dosovitskiy, Alexey and Beyer, Lucas and Kolesnikov, Alexander and Weissenborn, Dirk and Zhai, Xiaohua and Unterthiner, Thomas and Dehghani, Mostafa and Minderer, Matthias and Heigold, Georg and Gelly, Sylvain and Uszkoreit, Jakob and Houlsby, Neil},
  date = {2021-06},
  doi = {10.48550/arXiv.2010.11929},
  url = {http://arxiv.org/abs/2010.11929},
  urldate = {2026-02-28},
  abstract = {While the Transformer architecture has become the de-facto standard for natural language processing tasks, its applications to computer vision remain limited. In vision, attention is either applied in conjunction with convolutional networks, or used to replace certain components of convolutional networks while keeping their overall structure in place. We show that this reliance on CNNs is not necessary and a pure transformer applied directly to sequences of image patches can perform very well on image classification tasks. When pre-trained on large amounts of data and transferred to multiple mid-sized or small image recognition benchmarks (ImageNet, CIFAR-100, VTAB, etc.), Vision Transformer (ViT) attains excellent results compared to state-of-the-art convolutional networks while requiring substantially fewer computational resources to train.},
  langid = {english},
  organization = {arXiv},
  keywords = {Computer Science - Artificial Intelligence,Computer Science - Computer Vision and Pattern Recognition,Computer Science - Machine Learning}
}

