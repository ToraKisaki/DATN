@article{shokouhmand_fetal_2023,
	title = {Fetal {Electrocardiogram} {Extraction} {Using} {Dual}-{Path} {Source} {Separation} of {Single}-{Channel} {Non}-{Invasive} {Abdominal} {Recordings}},
	volume = {70},
	issn = {1558-2531},
	doi = {10.1109/TBME.2022.3189617},
	abstract = {OBJECTIVE: The development of a method for non-invasive monitoring of fetal electrocardiogram (FECG) signals from single-channel abdominal recordings. METHODS: The dual-path source separation (DPSS) architecture is introduced for the simultaneous separation of fetal and maternal ECG signals from abdominal ECG recordings. DPSS initially denoises abdominal ECG (AECG) recordings using a generative dual-path long short-term memory (DP-LSTM) network. An inception module along with a series of DP-LSTM blocks is then employed to extract the masking maps associated with fetal and maternal components. Finally, these masking maps are weighted by the AECG recording to separate maternal and fetal ECG signals. The performance of this network is evaluated on 10 pregnancies from the fetal ECG synthetic database (FECGSYNDB), 22 cases of labor and pregnancy from the abdominal and direct fetal ECG database (ADFECGDB), and 69 pregnancies from set A of non-invasive FECG challenge (NIFECGC) datasets. RESULTS: F1-scores of 99.03\%, 97.7\%, and 95.3\% are reported for the detection of fetal QRS complexes in FECGSYNDB, ADFECGDB, and NIFECGC respectively. DPSS technique is also evaluated in terms of separability of fetal and maternal clusters. According to the clustering-based analyses, the average purity index of 0.9750, Jaccard index of 0.9705, and Davies-Bouldin index of 0.7429 demonstrate the high source separation capability of DPSS. CONCLUSION: The achieved performance suggests that DPSS enables accurate single-channel FECG extraction, and can replace state-of-the-art source separation techniques for this purpose. SIGNIFICANCE: This study signifies a fundamental step towards non-invasive fetal ECG monitoring systems, which favors at-home prenatal care.},
	language = {eng},
	number = {1},
	journal = {IEEE transactions on bio-medical engineering},
	author = {Shokouhmand, Arash and Tavassolian, Negar},
	month = jan,
	year = {2023},
	keywords = {Abdomen, Algorithms, Computer-Assisted, Electrocardiography, Female, Fetal Monitoring, Fetus, Humans, Pregnancy, Signal Processing},
	pages = {283--295},
}

@inproceedings{darmawahyuni_deep_2023,
	title = {Deep {Learning} for {Fetal} {QRS}-complex {Classification} in {Noninvasive} {Fetal} {Electrocardiogram}},
	url = {https://ieeexplore.ieee.org/document/10277016},
	doi = {10.1109/ICoDSA58501.2023.10277016},
	abstract = {Fetal QRS-complex generated from an abdominal electrocardiogram (ECG) is an effective noninvasive tool for accurately measuring the fetus well-being during pregnancy. Classification of fetal QRS is significant to avoid fetal heart abnormalities, such as asphyxia, bradycardia, and hypoxia. However, accurately classifying the fetal QRS-complex is hard because the characteristic fetal ECG (fECG) has small amount of signal energy and it has undesired signal components, including recording devices, movement artifacts, and fetal brain activity. The sophisticated fECG signal processing for fetal QRS-complex classification has been used in the literature. However, they mostly use human intervention for feature extraction, leading to time-consume and raising the measurement error. Hence, this study investigates deep learning (DL) that performs automated feature extraction tasks excellently. DL has excellence amount of data scales, which is its ability to automatically learn and improve from data without the need for explicit programming. A sequence-to-sequence learning task was generated using a hybrid four convolution layers as a part of convolutional neural networks and bidirectional long short-term memory (ConvBiLSTM). As the results, the performance is outstanding; the accuracy, sensitivity, specificity, precision, and F1-score were 100\%. The observed results show the proposed ConvBiLSTM model is worth evaluating their effectiveness for fetal QRS-complex classification.},
	urldate = {2026-02-28},
	booktitle = {2023 {International} {Conference} on {Data} {Science} and {Its} {Applications} ({ICoDSA})},
	author = {Darmawahyuni, Annisa and Tutuko, Bambang and Rachmatullah, Muhammad Naufal and Nurmaini, Siti and Firdaus, Firdaus and Ardiansyah, Muhammad and Sapitri, Ade Iriani and Islami, Anggun},
	month = aug,
	year = {2023},
	keywords = {Convolution, Deep learning, Electrocardiography, Feature extraction, Programming, Sensitivity, Signal processing algorithms, convBiLSTM, deep learning, fetal electrocardiogram, qrs-complex},
	pages = {215--218},
}

