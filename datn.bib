
@article{fotiadou_enhancement_2018,
	title = {Enhancement of low-quality fetal electrocardiogram based on time-sequenced adaptive filtering},
	volume = {56},
	issn = {1741-0444},
	url = {https://doi.org/10.1007/s11517-018-1862-8},
	doi = {10.1007/s11517-018-1862-8},
	abstract = {Extraction of a clean fetal electrocardiogram (ECG) from non-invasive abdominal recordings is one of the biggest challenges in fetal monitoring. An ECG allows for the interpretation of the electrical heart activity beyond the heart rate and heart rate variability. However, the low signal quality of the fetal ECG hinders the morphological analysis of its waveform in clinical practice. The time-sequenced adaptive filter has been proposed for performing optimal time-varying filtering of non-stationary signals having a recurring statistical character. In our study, the time-sequenced adaptive filter is applied to enhance the quality of multichannel fetal ECG after the maternal ECG is removed. To improve the performance of the filter in cases of low signal-to-noise ratio (SNR), we enhance the ECG reference signals by averaging consecutive ECG complexes. The performance of the proposed augmented time-sequenced adaptive filter is evaluated in both synthetic and real data from PhysioNet. This evaluation shows that the suggested algorithm clearly outperforms other ECG enhancement methods, in terms of uncovering the ECG waveform, even in cases with very low SNR. With the presented method, quality of the fetal ECG morphology can be enhanced to the extent that the ECG might be fit for use in clinical diagnostics.},
	language = {en},
	number = {12},
	urldate = {2026-02-16},
	journal = {Medical \& Biological Engineering \& Computing},
	author = {Fotiadou, E. and van Laar, J. O. E. H. and Oei, S. G. and Vullings, R.},
	month = dec,
	year = {2018},
	keywords = {Electrocardiography, Fetal ECG de-noising, Fetal ECG enhancement, Time-sequenced adaptive filter},
	pages = {2313--2323},
}

@inproceedings{ye_elevating_2024,
	title = {Elevating {Vision} {Transformer} {Performance}: {The} {KAN}-{VIT} {Model} for {Image} {Recognition}},
	issn = {2993-396X},
	shorttitle = {Elevating {Vision} {Transformer} {Performance}},
	url = {https://ieeexplore.ieee.org/document/10925129},
	doi = {10.1109/SWC62898.2024.00353},
	abstract = {In this paper, we propose an innovative image recognition model called KAN-VIT, which applies the Kolmogorov-Arnold Networks (KANs) architecture to the Vision Transformer (VIT), replacing the traditional multilayer perceptron (MLP) layers and the MLP head at the output. KANs are neural networks based on the Kolmogorov-Arnold representation theorem, which introduces learnable activation functions between nodes, parameterized by spline functions, thereby providing higher accuracy and interpretability. Based on this, the VIT model was improved by replacing the original MLP layers with KANs, and experiments were conducted on the CIFAR-10, Oxford Flowers, and MNIST datasets. The results show that the improved model has demonstrated superior performance on the test datasets. We also analyzed the interpretability of KANs, and the results show that the improved model not only has improved performance but also has advantages in the visualization and interpretability of the model.},
	urldate = {2026-02-27},
	booktitle = {2024 {IEEE} {Smart} {World} {Congress} ({SWC})},
	author = {Ye, Lvzhou and Guo, Zhen},
	month = dec,
	year = {2024},
	keywords = {Analytical models, Computer vision, Flowering plants, Head, Image recognition, KAN, MLP, Multilayer perceptrons, Neural networks, Spline Function, Splines (mathematics), Transformers, VisionTransformer, Visualization},
	pages = {2321--2328},
}

