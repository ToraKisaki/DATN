  title = {Elevating {{Vision Transformer Performance}}: {{The KAN-VIT Model}} for {{Image Recognition}}},
  shorttitle = {Elevating {{Vision Transformer Performance}}},
  booktitle = {2024 {{IEEE Smart World Congress}} ({{SWC}})},
